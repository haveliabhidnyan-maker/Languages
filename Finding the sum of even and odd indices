class Solution {
    static ArrayList<Integer> getSum(int N) {
        ArrayList<Integer> oddEven = new ArrayList<>();
        
        int sumOfEven = 0;
        int sumOfOdd = 0;

        for (int i = 0; i <= N; i++) {
            if (i % 2 == 0) {
                sumOfEven += i;
            } else {
                sumOfOdd += i;
            }
        }

        oddEven.add(sumOfOdd);
        oddEven.add(sumOfEven);

        return oddEven;
    }
}
