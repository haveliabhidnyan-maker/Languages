import java.util.Scanner;

public class multiplicationTable {
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);
        System.out.print("Enter the number: ");
        int N = input.nextInt();
        int sum = 0;
        int i = 0;
        while(i < N){
            sum += i;
            i += 2;
        }
        System.out.println(sum);
    }
}
