#include <stdio.h>

int main(){
  int n;
  scanf("%d", &n);
  int steps = 0;

  while(n>10){
    int sum = 0;
    while(n>0){
      sum += n % 10;
      n = n/10;
    }
    n = sum;
    steps++;
  }

  printf("The digital root would be: %d \n", n);
  printf("The number of steps would be :%d \n", steps);

  return 0;
}
