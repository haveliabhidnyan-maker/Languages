#include <stdio.h>

int main() {
    int choice;
    double r, l, b, p, q, area;

    scanf("%d", &choice);

    switch (choice) {
        case 1:
            scanf("%lf", &r);
            area = 3.14 * r * r;
            printf("%.2lf sq.units", area);
            break;

        case 2:
            scanf("%lf %lf", &l, &b);
            area = l * b;
            printf("%.2lf sq.units", area);
            break;

        case 3:
            scanf("%lf %lf", &p, &q);
            area = 0.5 * p * q;
            printf("%.2lf sq.units", area);
            break;

        default:
            printf("Invalid choice");
    }

    return 0;
}
