class Construct{


        String name;
        int id;


        Construct(String name, int id)
        {
            this.name = name;
            this.id = id;
        }


        Construct(Construct obj2)
        {
            this.name = obj2.name;
            this.id = obj2.id;
        }
    }

    class ABC {
        public static void main(String[] args)
        {
            
            System.out.println("First Object");
            Construct obj = new Construct("Abhidnyan", 19);
            System.out.println("ObjName: " + obj.name
                    + " and ObjId: " + obj.id);

            System.out.println();

            
            Construct obj2 = new Construct(obj);
            System.out.println(
                    "Copy Constructor used Second Object");
            System.out.println("Objname: " + obj2.name
                    + " and ObjID: " + obj2.id);
        }
    }
}
